<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LPQZLGFJVX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LPQZLGFJVX');
  </script>

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{% if tags %}{{ tags | join(', ') }}, {% endif %}Green Beans Coffee, グリーンビーンズコーヒー, GBC, 北参道, 千駄ヶ谷, ダガヤサンドウ, スペシャルティコーヒー, 自家焙煎, ペットフレンドリーカフェ, 東京カフェ">

  <!-- OGP -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="{{ ogType if ogType else 'article' }}">
  <meta property="og:site_name" content="Green Beans Coffee コラム">
  <meta property="og:url" content="https://greenbeanscoffeeambassador.com{{ page.url }}">
  {% if thumbnail %}
  <meta property="og:image" content="https://greenbeanscoffeeambassador.com{{ thumbnail }}">
  {% else %}
  <meta property="og:image" content="https://greenbeanscoffeeambassador.com/assets/images/hero_bg-1.jpg">
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  {% if thumbnail %}
  <meta name="twitter:image" content="https://greenbeanscoffeeambassador.com{{ thumbnail }}">
  {% else %}
  <meta name="twitter:image" content="https://greenbeanscoffeeambassador.com/assets/images/hero_bg-1.jpg">
  {% endif %}

  <link rel="canonical" href="https://greenbeanscoffeeambassador.com{{ page.url }}">
  <link rel="alternate" hreflang="ja" href="https://greenbeanscoffeeambassador.com{{ page.url }}">
  <link rel="alternate" hreflang="x-default" href="https://greenbeanscoffeeambassador.com{{ page.url }}">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="alternate" type="application/rss+xml" title="Green Beans Coffee コラム" href="https://greenbeanscoffeeambassador.com/feed.xml">

  <!-- CDN: Tailwind CSS v4 -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio"></script>

  <!-- CDN: Animate.css -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" media="print" onload="this.media='all'" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;600&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Noto Sans JP', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Noto Serif JP', serif; }
    html { scroll-behavior: smooth; overflow-x: hidden; }
  </style>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#4A3728',
            secondary: '#8B7355',
            accent: '#C9A86C',
            background: '#FAF8F5',
            text: '#2D2A26',
          }
        }
      }
    }
  </script>

  <!-- JSON-LD: @graph（CafeOrCoffeeShop + BreadcrumbList + BlogPosting + FAQPage を1本に統合） -->
  {% set faqItems = content | extractFAQ %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CafeOrCoffeeShop",
        "name": "Green Beans Coffee",
        "alternateName": "グリーンビーンズコーヒー",
        "description": "北参道・千駄ヶ谷のペットフレンドリー自家焙煎カフェ。店名看板のない隠れ家コーヒー専門店。グルテンフリーメニューあり。営業時間10:30〜20:00（L.O.19:30）。",
        "url": "https://greenbeanscoffeeambassador.com",
        "telephone": "+81-3-6447-0681",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "千駄ヶ谷3-30-1 RC APARTMENT 1階",
          "addressLocality": "渋谷区",
          "addressRegion": "東京都",
          "postalCode": "151-0051",
          "addressCountry": "JP"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 35.6775167,
          "longitude": 139.7078346
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "10:30",
          "closes": "20:00"
        },
        "priceRange": "￥1,000〜￥2,999",
        "servesCuisine": ["Coffee","Gluten-Free","Cafe"],
        "amenityFeature": [
          {"@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true},
          {"@type": "LocationFeatureSpecification", "name": "電源コンセント", "value": true},
          {"@type": "LocationFeatureSpecification", "name": "ペット同伴可", "value": true},
          {"@type": "LocationFeatureSpecification", "name": "テイクアウト", "value": true}
        ],
        "paymentAccepted": ["Cash","Credit Card","Electronic Money","QR Code Payment"],
        "currenciesAccepted": "JPY",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.7",
          "reviewCount": "537",
          "bestRating": "5",
          "worstRating": "1"
        },
        "review": {
          "@type": "Review",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "4.7",
            "bestRating": "5"
          },
          "author": {
            "@type": "Organization",
            "name": "Google Maps"
          },
          "url": "https://www.google.com/maps/place/グリーンビーンズコーヒー/@35.677521,139.7052597,17z"
        },
        "hasMap": "https://www.google.com/maps/place/Green+Beans+Coffee/@35.677521,139.7052597,17z/data=!3m1!4b1!4m6!3m5!1s0x60188d4404ef151f:0x85142d57557d0f87!8m2!3d35.6775167!4d139.7078346!16s%2Fg%2F11s4ybh4cr",
        "sameAs": [
          "https://www.instagram.com/green.beanscoffee",
          "https://www.youtube.com/@greenbeanscoffee9",
          "https://tabelog.com/tokyo/A1309/A130901/13277423"
        ]
      },
      {
        "@type": "Organization",
        "name": "Green Beans Coffee",
        "alternateName": "グリーンビーンズコーヒー",
        "url": "https://greenbeanscoffeeambassador.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://greenbeanscoffeeambassador.com/assets/images/hero_bg-1.jpg",
          "width": 1280,
          "height": 853
        },
        "description": "東京・渋谷区千駄ヶ谷の自家焙煎スペシャルティコーヒー専門店。店名看板のないペットフレンドリーカフェ。グルテンフリーメニューあり。",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "千駄ヶ谷3-30-1 RC APARTMENT 1階",
          "addressLocality": "渋谷区",
          "addressRegion": "東京都",
          "postalCode": "151-0051",
          "addressCountry": "JP"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+81-3-6447-0681",
          "contactType": "customer service",
          "availableLanguage": "Japanese"
        },
        "areaServed": {
          "@type": "City",
          "name": "東京"
        },
        "knowsAbout": ["スペシャルティコーヒー", "自家焙煎", "グルテンフリー", "ペットフレンドリーカフェ", "ハンドドリップ"],
        "sameAs": [
          "https://www.instagram.com/green.beanscoffee",
          "https://www.youtube.com/@greenbeanscoffee9",
          "https://tabelog.com/tokyo/A1309/A130901/13277423",
          "https://www.hotpepper.jp/strJ004509887/"
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "ホーム",
            "item": "https://greenbeanscoffeeambassador.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "記事",
            "item": "https://greenbeanscoffeeambassador.com/articles/"
          }{% if title and page.url != "/articles/" %},
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ title | dump | safe }},
            "item": "https://greenbeanscoffeeambassador.com{{ page.url }}"
          }{% endif %}
        ]
      }
      {% if date %},
      {
        "@type": "BlogPosting",
        "headline": {{ title | dump | safe }},
        "description": {{ description | dump | safe }},
        "datePublished": "{{ date | dateISO }}",
        "dateModified": "{{ date | dateISO }}",
        "author": {
          "@type": "Person",
          "@id": "https://greenbeanscoffeeambassador.com/#ambassador-{{ author or 'kikumi' | lower }}",
          "name": "{{ author or 'Kikumi' }}",
          "jobTitle": "GBCアンバサダー",
          "url": "https://greenbeanscoffeeambassador.com",
          "sameAs": [
            "https://greenbeanscoffeeambassador.com"{% if not author or author == "Kikumi" %},
            "https://horikikumi.pages.dev/"{% endif %}
          ],
          "knowsAbout": ["スペシャルティコーヒー", "自家焙煎コーヒー", "ペットフレンドリーカフェ", "グルテンフリー"]
        },
        "publisher": {
          "@type": "Organization",
          "name": "Green Beans Coffee アンバサダーサイト",
          "url": "https://greenbeanscoffeeambassador.com"
        },
        "image": "https://greenbeanscoffeeambassador.com{% if thumbnail %}{{ thumbnail }}{% else %}/assets/images/hero_bg-1.jpg{% endif %}",
        "url": "https://greenbeanscoffeeambassador.com{{ page.url }}",
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "https://greenbeanscoffeeambassador.com{{ page.url }}"
        },
        "speakable": {
          "@type": "SpeakableSpecification",
          "cssSelector": ["h1", "h2", "article .prose > p:first-of-type"]
        }
      }
      {% endif %}
      {% if faqItems | length > 0 %},
      {
        "@type": "FAQPage",
        "mainEntity": [
          {% for item in faqItems %}
          {
            "@type": "Question",
            "name": {{ item.q | dump | safe }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ item.a | dump | safe }}
            }
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
      }
      {% endif %},
      {
        "@type": "WebSite",
        "name": "Green Beans Coffee アンバサダーサイト",
        "url": "https://greenbeanscoffeeambassador.com",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://greenbeanscoffeeambassador.com/articles/?search={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>
</head>

<body class="bg-[#FAF8F5] text-[#2D2A26] overflow-x-hidden">

  <!-- Navigation（記事ページ専用：シンプル構成） -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/80 shadow-md text-[#4A3728] transition-all duration-300">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">

      <!-- 左：ブランド + ナビ -->
      <div class="flex items-center gap-4 text-sm">
        <a href="https://greenbeanscoffeeambassador.com/" class="font-semibold text-[#4A3728] hover:text-[#C9A86C] transition whitespace-nowrap">Green Beans Coffee</a>
        <span class="text-[#D0C4B0] hidden sm:block select-none">/</span>
        <span class="hidden sm:block text-xs font-bold text-[#4A3728]">Articles</span>
      </div>

      <!-- 右：言語切替 + Pet Site + モバイルメニューボタン -->
      <div class="flex items-center gap-3">
        <!-- Language Toggle -->
        <!-- 記事一覧リンク -->
        <a href="/articles/" class="hidden sm:flex items-center gap-1.5 text-xs text-[#8B7355] hover:text-[#4A3728] transition whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          記事一覧
        </a>

        <!-- Mobile menu button（スマホのみ） -->
        <button id="mobile-menu-btn" class="sm:hidden text-[#4A3728]" aria-label="メニューを開く">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu（スマホのみ） -->
    <div id="mobile-menu" class="hidden sm:hidden bg-white/95 backdrop-blur-md border-t border-[#E8E0D5]">
      <ul class="flex flex-col p-4 text-sm gap-1 text-[#4A3728]">
        <li>
          <a href="/" class="flex items-center gap-2 py-2 hover:text-[#C9A86C] transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
            メインサイトへ
          </a>
        </li>
        <li><a href="/articles/" class="block py-2 font-bold">Articles 一覧</a></li>
      </ul>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="pt-16">
    {{ content | safe }}
  </div>

  <!-- Footer -->
  <footer class="bg-[#4A3728] text-white/70 text-center py-8 text-xs mt-16">
    <p class="mb-2 text-white/90 font-medium">Green Beans Coffee アンバサダーサイト</p>
    <p class="mb-3">
      <a href="/articles/" class="hover:text-[#C9A86C] transition">記事一覧</a>
      <span class="mx-2 text-white/40">/</span>
      <a href="/" class="hover:text-[#C9A86C] transition">トップ</a>
    </p>
    <hr class="border-white/20 w-24 mx-auto mb-3">
    <p class="text-white/50">© 2026 GBCアンバサダー Kikumi. All rights reserved.</p>
  </footer>

  <script>
    document.getElementById('mobile-menu-btn').addEventListener('click', function() {
      document.getElementById('mobile-menu').classList.toggle('hidden');
    });

    // ① コピー時に著作権文言を自動付加
    document.addEventListener('copy', function(e) {
      const selection = window.getSelection();
      if (!selection || selection.toString().length < 10) return;
      const text = selection.toString();
      const attribution = '\n\n出典：Green Beans Coffee アンバサダーサイト\n' + window.location.href + '\n© 2026 GBCアンバサダー Kikumi. All rights reserved.\n掲載コンテンツの無断転載・複製を禁じます。';
      e.clipboardData.setData('text/plain', text + attribution);
      e.preventDefault();
    });
    // ② 右クリック無効化
    document.addEventListener('contextmenu', function(e) {
      e.preventDefault();
    });
  </script>

</body>
</html>
