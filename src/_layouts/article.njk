---
layout: articles-base.njk
---

<style>
  .special-h2 {
    background: #FAF8F5;
    border-left: 3px solid #C9A86C !important;
    border-bottom: none !important;
    padding: 8px 16px !important;
    margin-top: 3rem !important;
    border-radius: 0 4px 4px 0;
  }
</style>

<div class="max-w-6xl mx-auto px-4 py-12">

  <!-- パンくずリスト（フル幅） -->
  <nav class="text-xs text-[#8B7355] mb-6 flex items-center gap-1">
    <a href="/" class="hover:text-[#4A3728] transition">トップ</a>
    <span>/</span>
    <a href="/articles/" class="hover:text-[#4A3728] transition">Articles</a>
    <span>/</span>
    <span class="text-[#4A3728]">{{ title }}</span>
  </nav>

  <!-- 記事ヘッダー（フル幅） -->
  <header class="mb-10">
    <!-- タグ -->
    {% if tags %}
    <div class="flex flex-wrap gap-2 mb-4">
      {% for tag in tags %}
      {% if tag != "articles" %}
      <a href="/articles/tags/{{ tag }}/" class="text-xs bg-[#FAF8F5] text-[#8B7355] border border-[#E8E0D5] rounded-full px-3 py-1 hover:bg-[#C9A86C] hover:text-white hover:border-[#C9A86C] transition">{{ tag }}</a>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    <!-- タイトル -->
    <h1 class="text-2xl md:text-4xl font-bold text-[#4A3728] leading-snug mb-4">{{ title }}</h1>

    <!-- メタ情報 -->
    <div class="flex items-center gap-4 text-xs text-[#8B7355] border-b border-[#E8E0D5] pb-5">
      <span>{{ page.date | dateJa }}</span>
      <span>GBCアンバサダー Kikumi</span>
    </div>
  </header>

  <!-- 2カラムレイアウト（メタ情報の下から） -->
  <div class="flex flex-col lg:flex-row gap-10 mt-8">

    <!-- 本文エリア -->
    <article class="lg:w-2/3 min-w-0">

      <!-- アイキャッチ画像 -->
      {% if thumbnail %}
      <div class="rounded-xl overflow-hidden mb-8">
        <img src="{{ thumbnail }}" alt="{{ title }}" class="w-full object-cover" loading="lazy" decoding="async">
      </div>
      {% endif %}

      <div class="prose prose-stone max-w-none
        prose-headings:font-serif prose-headings:text-[#4A3728]
        prose-h2:text-xl prose-h2:border-b prose-h2:border-[#E8E0D5] prose-h2:pb-2 prose-h2:mt-10
        prose-h3:text-lg prose-h3:mt-8
        prose-p:text-[#2D2A26] prose-p:leading-relaxed
        prose-a:text-[#C9A86C] prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-lg
        prose-blockquote:border-l-[#C9A86C] prose-blockquote:bg-[#FAF8F5] prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-r-lg
        prose-strong:text-[#4A3728]">
        {{ content | safe }}
      </div>

      <!-- シェアボタン -->
      <div class="mt-12 pt-8 border-t border-[#E8E0D5] text-center">
        <p class="text-xs text-[#8B7355] mb-4">この記事をシェア</p>
        <div class="inline-flex items-center gap-4">
          <!-- X (Twitter) -->
          <a id="share-x" href="#" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 border border-[#D0C4B0] text-[#8B7355] text-xs px-4 py-2 rounded-full hover:border-[#4A3728] hover:text-[#4A3728] transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.856L1.254 2.25H8.08l4.259 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            ポスト
          </a>
          <!-- LINE -->
          <a id="share-line" href="#" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 border border-[#D0C4B0] text-[#8B7355] text-xs px-4 py-2 rounded-full hover:border-[#4A3728] hover:text-[#4A3728] transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            LINE
          </a>
          <!-- Facebook -->
          <a id="share-fb" href="#" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 border border-[#D0C4B0] text-[#8B7355] text-xs px-4 py-2 rounded-full hover:border-[#4A3728] hover:text-[#4A3728] transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
        </div>
      </div>

      <!-- 記事フッター -->
      <div class="mt-8 pt-6 border-t border-[#E8E0D5] text-center">
        <a href="/#faq" class="inline-flex items-center gap-2 text-sm text-[#8B7355] hover:text-[#4A3728] transition">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          店舗についてのよくある質問はこちら
        </a>
      </div>
    </article>

    <!-- サイドバー -->
    <aside class="lg:w-1/3">
      <div class="sticky top-24 space-y-8">

        <!-- カテゴリ一覧 -->
        <div class="bg-white rounded-xl border border-[#E8E0D5] p-6">
          <h2 class="text-sm font-bold text-[#4A3728] mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            カテゴリ
          </h2>
          <ul class="space-y-1 text-sm">
            {% for tag in collections.tagList %}
            <li>
              <a href="/articles/tags/{{ tag }}/" class="flex items-center justify-between py-1.5 text-[#8B7355] hover:text-[#4A3728] transition group">
                <span class="group-hover:text-[#C9A86C] transition">{{ tag }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-40"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>

        <!-- 最新記事 -->
        <div class="bg-white rounded-xl border border-[#E8E0D5] p-6">
          <h2 class="text-sm font-bold text-[#4A3728] mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            最新記事
          </h2>
          <ul class="space-y-3">
            {% for post in collections.articles | slice(0, 5) %}
            {% if post.url != page.url %}
            <li>
              <a href="{{ post.url }}" class="flex gap-3 group">
                {% if post.data.thumbnail %}
                <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-16 h-12 object-cover rounded flex-shrink-0" loading="lazy">
                {% else %}
                <div class="w-16 h-12 bg-[#FAF8F5] rounded flex-shrink-0 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A86C" stroke-width="1.5"><path d="M17 3H7a2 2 0 0 0-2 2v16l7-3 7 3V5a2 2 0 0 0-2-2z"/></svg>
                </div>
                {% endif %}
                <div>
                  <p class="text-xs text-[#2D2A26] leading-snug group-hover:text-[#C9A86C] transition line-clamp-2">{{ post.data.title }}</p>
                  <p class="text-xs text-[#B0A090] mt-1">{{ post.date | dateJa }}</p>
                </div>
              </a>
            </li>
            {% endif %}
            {% endfor %}
          </ul>
        </div>

        <!-- メインサイトへの誘導 -->
        <div class="bg-[#FAF8F5] rounded-xl border border-[#E8E0D5] p-6 text-center">
          <p class="text-xs text-[#8B7355] mb-3">Green Beans Coffee の<br>店舗情報・メニュー・アクセス</p>
          <a href="/" class="inline-block bg-[#4A3728] text-white text-xs px-5 py-2.5 rounded-lg hover:bg-[#8B7355] transition">
            メインサイトへ
          </a>
        </div>

      </div>
    </aside>

  </div>
</div>

<script>
  // まとめ・よくある質問 の h2 に特別スタイルを適用
  document.querySelectorAll('article h2').forEach(function(h2) {
    var text = h2.textContent.trim();
    if (['まとめ', 'よくある質問', 'FAQ', 'Summary', 'Conclusion'].includes(text)) {
      h2.classList.add('special-h2');
    }
  });

  // SNS シェアボタンのURL設定
  var pageUrl = encodeURIComponent(location.href);
  var pageTitle = encodeURIComponent(document.title);
  var shareX = document.getElementById('share-x');
  var shareLine = document.getElementById('share-line');
  var shareFb = document.getElementById('share-fb');
  if (shareX) shareX.href = 'https://twitter.com/intent/tweet?url=' + pageUrl + '&text=' + pageTitle;
  if (shareLine) shareLine.href = 'https://social-plugins.line.me/lineit/share?url=' + pageUrl;
  if (shareFb) shareFb.href = 'https://www.facebook.com/sharer/sharer.php?u=' + pageUrl;
</script>
