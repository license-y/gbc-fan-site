---
layout: articles-base.njk
---

<div class="max-w-6xl mx-auto px-4 py-12">

  <!-- パンくずリスト -->
  <nav class="text-xs text-[#8B7355] mb-6 flex items-center gap-1">
    <a href="/" class="hover:text-[#4A3728] transition">トップ</a>
    <span>/</span>
    <a href="/articles/" class="hover:text-[#4A3728] transition">Articles</a>
    <span>/</span>
    <span class="text-[#4A3728]">{{ title }}</span>
  </nav>

  <div class="flex flex-col lg:flex-row gap-10">

    <!-- メイン記事エリア -->
    <article class="lg:w-2/3">
      <!-- 記事ヘッダー -->
      <header class="mb-8">
        <!-- タグ -->
        {% if tags %}
        <div class="flex flex-wrap gap-2 mb-4">
          {% for tag in tags %}
          {% if tag != "articles" %}
          <a href="/articles/tags/{{ tag }}/" class="text-xs bg-[#FAF8F5] text-[#8B7355] border border-[#E8E0D5] rounded-full px-3 py-1 hover:bg-[#C9A86C] hover:text-white hover:border-[#C9A86C] transition">{{ tag }}</a>
          {% endif %}
          {% endfor %}
        </div>
        {% endif %}

        <!-- タイトル -->
        <h1 class="text-2xl md:text-3xl font-bold text-[#4A3728] leading-snug mb-4">{{ title }}</h1>

        <!-- メタ情報 -->
        <div class="flex items-center gap-4 text-xs text-[#8B7355] border-b border-[#E8E0D5] pb-4">
          <span>{{ page.date | dateJa }}</span>
          <span>GBCアンバサダー Kikumi</span>
        </div>
      </header>

      <!-- アイキャッチ画像 -->
      {% if thumbnail %}
      <div class="mb-8 rounded-xl overflow-hidden">
        <img src="{{ thumbnail }}" alt="{{ title }}" class="w-full object-cover" loading="lazy" decoding="async">
      </div>
      {% endif %}

      <!-- 記事本文 -->
      <div class="prose prose-stone max-w-none
        prose-headings:font-serif prose-headings:text-[#4A3728]
        prose-h2:text-xl prose-h2:border-b prose-h2:border-[#E8E0D5] prose-h2:pb-2 prose-h2:mt-10
        prose-h3:text-lg prose-h3:mt-8
        prose-p:text-[#2D2A26] prose-p:leading-relaxed
        prose-a:text-[#C9A86C] prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-lg
        prose-blockquote:border-l-[#C9A86C] prose-blockquote:bg-[#FAF8F5] prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-r-lg
        prose-strong:text-[#4A3728]
        prose-ul:list-disc prose-ol:list-decimal">
        {{ content | safe }}
      </div>

      <!-- 記事フッター（FAQ・関連記事誘導） -->
      <div class="mt-12 pt-8 border-t border-[#E8E0D5]">
        <a href="/#faq" class="inline-flex items-center gap-2 text-sm text-[#8B7355] hover:text-[#4A3728] transition">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          店舗についてのよくある質問はこちら
        </a>
      </div>
    </article>

    <!-- サイドバー -->
    <aside class="lg:w-1/3">
      <div class="sticky top-24 space-y-8">

        <!-- カテゴリ一覧 -->
        <div class="bg-white rounded-xl border border-[#E8E0D5] p-6">
          <h2 class="text-sm font-bold text-[#4A3728] mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            カテゴリ
          </h2>
          <ul class="space-y-1 text-sm">
            {% for tag in collections.tagList %}
            <li>
              <a href="/articles/tags/{{ tag }}/" class="flex items-center justify-between py-1.5 text-[#8B7355] hover:text-[#4A3728] transition group">
                <span class="group-hover:text-[#C9A86C] transition">{{ tag }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-40"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>

        <!-- 最新記事 -->
        <div class="bg-white rounded-xl border border-[#E8E0D5] p-6">
          <h2 class="text-sm font-bold text-[#4A3728] mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            最新記事
          </h2>
          <ul class="space-y-3">
            {% for post in collections.articles | slice(0, 5) %}
            {% if post.url != page.url %}
            <li>
              <a href="{{ post.url }}" class="flex gap-3 group">
                {% if post.data.thumbnail %}
                <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-16 h-12 object-cover rounded flex-shrink-0" loading="lazy">
                {% else %}
                <div class="w-16 h-12 bg-[#FAF8F5] rounded flex-shrink-0 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A86C" stroke-width="1.5"><path d="M17 3H7a2 2 0 0 0-2 2v16l7-3 7 3V5a2 2 0 0 0-2-2z"/></svg>
                </div>
                {% endif %}
                <div>
                  <p class="text-xs text-[#2D2A26] leading-snug group-hover:text-[#C9A86C] transition line-clamp-2">{{ post.data.title }}</p>
                  <p class="text-xs text-[#B0A090] mt-1">{{ post.date | dateJa }}</p>
                </div>
              </a>
            </li>
            {% endif %}
            {% endfor %}
          </ul>
        </div>

        <!-- メインサイトへの誘導 -->
        <div class="bg-[#FAF8F5] rounded-xl border border-[#E8E0D5] p-6 text-center">
          <p class="text-xs text-[#8B7355] mb-3">Green Beans Coffee の<br>店舗情報・メニュー・アクセス</p>
          <a href="/" class="inline-block bg-[#4A3728] text-white text-xs px-5 py-2.5 rounded-lg hover:bg-[#8B7355] transition">
            メインサイトへ
          </a>
        </div>

      </div>
    </aside>

  </div>
</div>
