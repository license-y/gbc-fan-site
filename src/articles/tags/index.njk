---
layout: articles-base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /articles/tags/{{ tag }}/index.html
eleventyComputed:
  title: "{{ tag }} の記事一覧 | GBC コラム"
  description: "Green Beans Coffee に関する「{{ tag }}」カテゴリの記事一覧です。"
---

<main class="max-w-5xl mx-auto px-4 py-12">

  <div class="mb-10">
    <nav class="text-xs text-[#8B7355] mb-4 flex items-center gap-1">
      <a href="/" class="hover:text-[#4A3728] transition">トップ</a>
      <span>/</span>
      <a href="/articles/" class="hover:text-[#4A3728] transition">Articles</a>
      <span>/</span>
      <span class="text-[#4A3728]">{{ tag }}</span>
    </nav>
    <h1 class="text-2xl font-bold text-[#4A3728] mb-1">{{ tag }}</h1>
    <p class="text-sm text-[#8B7355]">カテゴリ「{{ tag }}」の記事一覧</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {%- set taggedPosts = collections[tag] %}
    {%- if taggedPosts %}
    {%- for post in taggedPosts | reverse %}
    <a href="{{ post.url }}" class="group block bg-white rounded-xl border border-[#E8E0D5] overflow-hidden hover:shadow-md transition-shadow duration-200">
      {%- if post.data.thumbnail %}
      <div class="aspect-video overflow-hidden">
        <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
      </div>
      {%- endif %}
      <div class="p-5">
        <h2 class="text-base font-bold text-[#2D2A26] mb-2 group-hover:text-[#4A3728] leading-snug">{{ post.data.title }}</h2>
        {%- if post.data.description %}
        <p class="text-sm text-[#8B7355] line-clamp-2">{{ post.data.description }}</p>
        {%- endif %}
        <p class="text-xs text-[#B0A090] mt-3">{{ post.date | dateJa }}</p>
      </div>
    </a>
    {%- endfor %}
    {%- endif %}
  </div>

  <div class="mt-12 text-center">
    <a href="/articles/" class="inline-flex items-center gap-2 text-sm text-[#8B7355] hover:text-[#4A3728] transition">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
      記事一覧に戻る
    </a>
  </div>

</main>
