---
layout: articles-base.njk
title: GBC コラム | Green Beans Coffee アンバサダーサイト
description: 北参道・千駄ヶ谷のGreen Beans Coffeeにまつわるコラム記事一覧。スペシャルティコーヒー・グルテンフリー・ペット同伴カフェ・焙煎体験・サードプレイスをテーマに随時更新中。
permalink: /articles/index.html
---

<style>
  /* Pagefind UI カスタマイズ */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #4A3728;
    --pagefind-ui-text: #2D2A26;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #E8E0D5;
    --pagefind-ui-tag: #FAF8F5;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 9999px;
    --pagefind-ui-font: 'Noto Sans JP', sans-serif;
  }
  .pagefind-ui__search-input {
    font-size: 0.875rem !important;
  }
  .pagefind-ui__result-title {
    color: #4A3728 !important;
  }
  .pagefind-ui__result-excerpt {
    font-size: 0.8rem !important;
    color: #8B7355 !important;
  }
  mark {
    background: #F5EDD8 !important;
    color: #4A3728 !important;
    border-radius: 2px;
    padding: 0 2px;
  }
</style>

<main class="max-w-4xl mx-auto px-4 py-12">

  <div class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-[#4A3728] mb-2">GBC Articles</h1>
    <p class="text-sm text-[#8B7355]">Green Beans Coffee にまつわるコーヒー・ペット・グルテンフリー・体験イベントの記事</p>
  </div>

  <!-- 検索ボックス -->
  <div id="search" class="mb-8 max-w-lg mx-auto"></div>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    window.addEventListener('DOMContentLoaded', function() {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search',
          showSubResults: false,
          showImages: false,
          translations: {
            placeholder: '記事を検索...',
            zero_results: '「[SEARCH_TERM]」に一致する記事はありません'
          }
        });
      }
    });
  </script>

  {%- if collections.articles.length == 0 %}
  <p class="text-center text-[#8B7355] py-20">記事を準備中です。</p>
  {%- else %}

  <!-- カテゴリフィルター（モバイル：3段） -->
  <div class="flex flex-col items-center gap-1.5 mb-8 md:hidden" id="category-filters">
    <div class="flex justify-center gap-1.5">
      <button data-category="all" class="filter-btn text-[10px] px-2.5 py-1 rounded-full border border-[#4A3728] bg-[#4A3728] text-white">すべて</button>
      {%- for cat in ["コーヒー", "焙煎", "グルテンフリー"] %}
      <button data-category="{{ cat }}" class="filter-btn text-[10px] px-2.5 py-1 rounded-full border border-[#D0C4B0] text-[#8B7355] hover:border-[#4A3728] hover:text-[#4A3728]">{{ cat }}</button>
      {%- endfor %}
    </div>
    <div class="flex justify-center gap-1.5">
      {%- for cat in ["体験・イベント", "ペット", "美容健康", "ビジネス"] %}
      <button data-category="{{ cat }}" class="filter-btn text-[10px] px-2.5 py-1 rounded-full border border-[#D0C4B0] text-[#8B7355] hover:border-[#4A3728] hover:text-[#4A3728]">{{ cat }}</button>
      {%- endfor %}
    </div>
    <div class="flex justify-center gap-1.5">
      {%- for cat in ["サードプレイス", "店内", "ダガヤサンドウ"] %}
      <button data-category="{{ cat }}" class="filter-btn text-[10px] px-2.5 py-1 rounded-full border border-[#D0C4B0] text-[#8B7355] hover:border-[#4A3728] hover:text-[#4A3728]">{{ cat }}</button>
      {%- endfor %}
    </div>
  </div>

  <!-- カテゴリフィルター（PC：2段） -->
  <div class="hidden md:flex flex-col items-center gap-2 mb-8">
    <div class="flex justify-center gap-2">
      <button data-category="all" class="filter-btn text-xs px-3 py-1.5 rounded-full border border-[#4A3728] bg-[#4A3728] text-white">すべて</button>
      {%- for cat in ["コーヒー", "焙煎", "グルテンフリー", "体験・イベント", "ペット"] %}
      <button data-category="{{ cat }}" class="filter-btn text-xs px-3 py-1.5 rounded-full border border-[#D0C4B0] text-[#8B7355] hover:border-[#4A3728] hover:text-[#4A3728]">{{ cat }}</button>
      {%- endfor %}
    </div>
    <div class="flex justify-center gap-2">
      {%- for cat in ["美容健康", "ビジネス", "サードプレイス", "店内", "ダガヤサンドウ"] %}
      <button data-category="{{ cat }}" class="filter-btn text-xs px-3 py-1.5 rounded-full border border-[#D0C4B0] text-[#8B7355] hover:border-[#4A3728] hover:text-[#4A3728]">{{ cat }}</button>
      {%- endfor %}
    </div>
  </div>

  <!-- 記事リスト -->
  <div class="flex flex-col gap-4" id="articles-list">
    {%- for post in collections.articles %}
    {%- set postTags = [] %}
    {%- for tag in post.data.tags %}
      {%- if tag != "articles" %}
        {%- set postTags = (postTags.push(tag), postTags) %}
      {%- endif %}
    {%- endfor %}
    <a href="{{ post.url }}"
      class="article-card group flex bg-white rounded-xl border border-[#E8E0D5] overflow-hidden hover:shadow-md transition-shadow duration-200"
      data-tags="{{ postTags | join(',') }}">

      <!-- サムネイル -->
      {%- if post.data.thumbnail %}
      <div class="w-32 sm:w-44 h-28 sm:h-32 flex-shrink-0 overflow-hidden">
        <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
      </div>
      {%- else %}
      <div class="w-32 sm:w-44 h-28 sm:h-32 flex-shrink-0 bg-[#FAF8F5] flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#D0C4B0" stroke-width="1.5"><path d="M17 3H7a2 2 0 0 0-2 2v16l7-3 7 3V5a2 2 0 0 0-2-2z"/></svg>
      </div>
      {%- endif %}

      <!-- テキスト -->
      <div class="p-4 sm:p-5 flex flex-col justify-between flex-1 min-w-0">
        <div>
          {%- if postTags.length > 0 %}
          <div class="flex flex-wrap gap-1 mb-2">
            {%- for tag in postTags %}
            <span class="text-xs bg-[#FAF8F5] text-[#8B7355] border border-[#E8E0D5] rounded-full px-2 py-0.5">{{ tag }}</span>
            {%- endfor %}
          </div>
          {%- endif %}
          <h2 class="text-sm sm:text-base font-bold text-[#2D2A26] group-hover:text-[#4A3728] leading-snug mb-1">{{ post.data.title }}</h2>
          {%- if post.data.description %}
          <p class="text-xs text-[#8B7355] line-clamp-2 hidden sm:block">{{ post.data.description }}</p>
          {%- endif %}
        </div>
        <p class="text-xs text-[#B0A090] mt-2">{{ post.date | dateJa }}</p>
      </div>
    </a>
    {%- endfor %}
  </div>

  <!-- 該当記事なし -->
  <p id="no-results" class="hidden text-center text-[#8B7355] py-12 text-sm">このカテゴリの記事はまだありません。</p>

  {%- endif %}

</main>

<script>
  var buttons = document.querySelectorAll('.filter-btn');
  var cards = document.querySelectorAll('.article-card');
  var noResults = document.getElementById('no-results');

  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var category = btn.dataset.category;

      // 全ボタンを非アクティブに（モバイル・PC両レイアウト対象）
      buttons.forEach(function(b) {
        b.classList.remove('bg-[#4A3728]', 'text-white', 'border-[#4A3728]');
        b.classList.add('border-[#D0C4B0]', 'text-[#8B7355]', 'hover:text-[#4A3728]', 'hover:border-[#4A3728]');
      });
      // 同じdata-categoryを持つ全ボタンをアクティブに（モバイル・PC同期）
      document.querySelectorAll('.filter-btn[data-category="' + category + '"]').forEach(function(b) {
        b.classList.remove('border-[#D0C4B0]', 'text-[#8B7355]', 'hover:text-[#4A3728]', 'hover:border-[#4A3728]');
        b.classList.add('bg-[#4A3728]', 'text-white', 'border-[#4A3728]');
      });

      // カードの表示・非表示
      var visible = 0;
      cards.forEach(function(card) {
        var tags = card.dataset.tags ? card.dataset.tags.split(',') : [];
        var show = category === 'all' || tags.includes(category);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
